{
  "name": "personal-cloud-backup-client",
  "version": "1.0.0",
  "description": "Personal Cloud Backup System",
  "productName": "Personal Cloud Backup",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "pack": "electron-builder --win --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mycloudbackup.desktop",
    "productName": "Personal Cloud Backup",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "styles.css",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../build/backup_core.exe",
        "to": "bin/backup_core.exe"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
